{
  "name": "stocky-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch server.js",
    "start": "node server.js",
    "migrate": "node src/database/migrate.js",
    "db:pull": "npx prisma db pull",
    "db:generate": "npx prisma generate",
    "db:sync": "npm run migrate && npx prisma db pull && npx prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "chalk": "^5.6.2",
    "dotenv": "^16.5.0",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "prisma": "^6.9.0"
  }
}
